datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
  output   = "./client-generated"
}

model PolizyTuple {
  id          String @id @default(cuid())
  subjectType String
  subjectId   String
  relation    String
  objectType  String
  objectId    String
  condition   Json?

  // Each relationship is unique; enables idempotent upserts.
  @@unique([subjectType, subjectId, relation, objectType, objectId])
  // Lookups: "what does this subject have?" and "who has this object?"
  @@index([subjectType, subjectId, relation])
  @@index([objectType, objectId, relation])
}
