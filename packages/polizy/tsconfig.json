{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "rootDir": "./src",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/scenarios/**",
    "src/polizy.storage.shared-tests.ts",
    "dist",
    "node_modules",
    "prisma/client-generated"
  ]
}
